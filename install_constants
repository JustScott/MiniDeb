# Recommended Partition Sizes:
#   - 1GB EFI, 1GB Boot, atleast 10GB Root, remaining Home
declare -r EFI_PARTITION="/dev/vda1"
declare -r BOOT_PARTITION="/dev/vda2"
declare -r ROOT_PARTITION="/dev/vda3"
declare -r HOME_PARTITION="/dev/vda4"
declare -r OVERWRITE_HOME_PARTITION='n' # 'y' overwrites, 'n' uses existing
declare -r KEYFILE_PARTITION=""

# Leave empty for no swap. Max is 32. Will have issues if swap is close
# to root partition size
declare -r SWAP_SIZE_IN_GB='4'

# Useful in large deployments, change value accordingly
#declare -r APT_CACHE_SERVER="http://192.168.8.190:3142/"
#declare -r APT_CACHE_FILE="/etc/apt/apt.conf.d/10proxy"

# Leave empty or comment out for a headless install
#  - Supported values: 'gnome'
declare -r DESKTOP_ENVIRONMENT='gnome'
